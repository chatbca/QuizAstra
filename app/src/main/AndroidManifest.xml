<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.svvaap.quizastra">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Optional: legacy permission for older Android versions when picking images -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <!-- Notifications (effective on Android 13+); harmless on lower/target 32 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".QuizAstraApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuizAstra">
        <activity
            android:name=".UserResult"
            android:exported="false" />
        <activity
            android:name=".QuizQuestion"
            android:exported="false" />
        <activity
            android:name=".UserProfile"
            android:exported="false" />
        <activity
            android:name=".UserDashboard"
            android:exported="false" /> <!-- Splash screen is the launcher -->
        <activity
            android:name=".Splashscreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- Main Dashboard after login -->
        <activity
            android:name=".MainActivity"
            android:exported="false" /> <!-- Login and Register screens -->
        <activity
            android:name=".UserLogin"
            android:exported="false" />
        <activity
            android:name=".UserRegister"
            android:exported="false" /> <!-- Leaderboard screen -->
        <activity
            android:name=".LeaderboardActivity"
            android:exported="false" />
        <activity
            android:name=".BattleActivity"
            android:exported="false" />
        <activity
            android:name=".BattleCountdownActivity"
            android:exported="false" />
    </application>

</manifest>